# Replace DEMO_DOMAIN with your subdomain (e.g. demo.blackarcsystems.com)
DEMO_DOMAIN {
	# Static file server for SCAP evidence packages (PDFs + POA&M CSVs).
	# scap_evidence_pack defaults to writing into /tmp/scap-out — keep
	# the path here aligned with what the agent picks. `browse` shows
	# the directory listing so the presenter can refresh and see new
	# artifacts appear. Public read — sanitized data only, no secrets.
	# (Caddy's stock unit has PrivateTmp=yes, which would isolate this
	# /tmp from the agent's. setup-vm.sh installs an override to flip
	# it off so both processes share the same /tmp.)
	handle_path /artifacts/* {
		root * /tmp/scap-out
		file_server browse
	}

	reverse_proxy 127.0.0.1:8420 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
	}

	# WebSocket upgrades for live agent traces
	@websockets {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websockets 127.0.0.1:8420

	encode zstd gzip

	log {
		output file /var/log/caddy/arc-access.log
		format json
	}
}

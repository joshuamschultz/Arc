# ArcAgent Configuration
# Copy to arcagent.toml and customize.
# Environment variables override with ARCAGENT_ prefix (e.g., ARCAGENT_LLM__MODEL)

[agent]
name = "my-agent"
org = "default"
type = "executor"          # executor | planner | reviewer
workspace = "./workspace"

[llm]
model = "anthropic/claude-sonnet-4-5-20250929"
max_tokens = 4096
temperature = 0.7

[identity]
did = ""                   # Auto-generated if empty
key_dir = "~/.arcagent/keys"
vault_path = ""            # Empty = file-based keys (dev mode)

[vault]
backend = ""               # "module:Class" format. Empty = disabled (dev mode)
cache_ttl_seconds = 300

[tools.policy]
allow = []                 # Empty = allow all
deny = []
timeout_seconds = 30

# Native tools (Python functions)
# [tools.native.read_file]
# module = "arcagent.tools.fs:read_file"
# description = "Read a file from the workspace"

# MCP servers
# [tools.mcp_servers.filesystem]
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem"]
# timeout_seconds = 30

# HTTP tools
# [tools.http.weather]
# url = "https://api.weather.gov/points"
# method = "GET"
# timeout_seconds = 10

# Process tools
# [tools.process.git_status]
# command = "git"
# args = ["status"]
# timeout_seconds = 10

[telemetry]
enabled = true
service_name = "arcagent"
log_level = "INFO"
export_traces = false
exporter_endpoint = ""     # e.g., "http://localhost:4317" for OTel Collector

[context]
max_tokens = 128000
prune_threshold = 0.70     # Start masking old tool outputs
compact_threshold = 0.85   # LLM summarization
emergency_threshold = 0.95 # Force truncation
estimate_multiplier = 1.1  # Conservative token estimate buffer

# Eval model — used for entity extraction, policy evaluation, compaction
# [eval]
# provider = ""            # Empty = use same provider as agent
# model = ""               # Empty = use agent's model
# max_tokens = 1024
# temperature = 0.2
# timeout_seconds = 30
# fallback_behavior = "skip"  # "skip" | "error"
# max_concurrent = 2
# background_queue_size = 10      # Per-module background task queue depth
# background_task_timeout = 120   # Seconds before background task timeout

# Session management
# [session]
# retention_count = 50     # Keep last N sessions
# retention_days = 30      # Or sessions from last N days
# compaction_summary_max_chars = 2000

# --- Modules ---
# Each module has [modules.NAME] for enable/priority and
# [modules.NAME.config] for module-specific settings.

# Memory module (thin Brain wiring — SPEC-041)
# Scaffolded agents get memory ON (brain = "arcmemory"): zero-LLM capture writes
# daily-log bullets (workspace/memory/daily-log/YYYY-MM-DD.md), the episodic index
# (workspace/memory/index.db), and the entity graph each turn. Set brain = "none"
# for a no-op NullBrain (zero memory files), or a dotted `module:Class` path for a
# bring-your-own Brain. Consolidation (entity cards + facts + insights) is opt-in:
# set distill_provider/distill_model to an LLM to enable it.
# [modules.memory]
# enabled = true
# priority = 100
#
# [modules.memory.config]
# brain = "arcmemory"               # arcmemory | none | auto | module:Class
# tier = "personal"
# top_k = 5
# budget = 1024
# distill_provider = ""             # e.g. "anthropic" to enable consolidation
# distill_model = ""
# consolidate_event_threshold = 20
# consolidate_idle_seconds = 900.0

# Policy module
# [modules.policy]
# enabled = true
# priority = 100
#
# [modules.policy.config]
# eval_interval_turns = 20
# max_bullets = 200
# max_bullet_text_length = 500

# Scheduler module
# [modules.scheduler]
# enabled = false
# priority = 100
#
# [modules.scheduler.config]
# min_interval_seconds = 60
# max_schedules = 50
# max_prompt_length = 500
# default_timeout_seconds = 300
# max_timeout_seconds = 3600
# circuit_breaker_threshold = 3
# check_interval_seconds = 30
# store_path = "schedules.json"
